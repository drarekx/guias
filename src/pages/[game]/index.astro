---
import GuideLayout from "../../layouts/GuideLayout.astro";
import Logo from "../../components/Logo.astro";
import { totalPagesFor, loadGame, isGameAvailable } from "../../lib/guide";
import { GAMES, getGame, type Game } from "../../lib/games";
import { themeVars } from "../../lib/games";

export function getStaticPaths() {
  return GAMES.filter(g => isGameAvailable(g.slug)).map(g => ({
    params: { game: g.slug },
    props: { game: g },
  }));
}

interface Props { game: Game; }
const { game } = Astro.props;

const { structure } = loadGame(game.slug);
const total = totalPagesFor(game.slug);

const accentColors = ["var(--color-crystal)", "var(--color-gold)", "var(--color-rose)", "var(--color-azure)", "var(--color-emerald)", "var(--color-ember)"];
const stats = [
  { label: "Capítulos", value: total, accent: "var(--color-crystal)" },
  { label: structure.length > 4 ? "Secciones" : "Discos", value: structure.length, accent: "var(--color-gold)" },
  { label: "Año", value: game.year, accent: "var(--color-rose)" },
  { label: "Plataforma", value: game.platforms[0], accent: "var(--color-emerald)" },
];
---
<GuideLayout
  title={`Guía ${game.title} · Tomo del Cristal`}
  description={`Guía completa de ${game.title} al 100% — walkthrough y extras.`}
  game={game}
>
  <div class="relative">
    <section class="relative overflow-hidden">
      <svg class="absolute inset-0 w-full h-full opacity-[0.07] pointer-events-none" viewBox="0 0 1200 600" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
        <defs>
          <radialGradient id="hglow" cx="0.5" cy="0.5" r="0.5">
            <stop offset="0" stop-color={game.theme.primary.hex} stop-opacity="0.8"/>
            <stop offset="1" stop-color={game.theme.primary.hex} stop-opacity="0"/>
          </radialGradient>
        </defs>
        <circle cx="220" cy="180" r="120" fill="url(#hglow)"/>
        <circle cx="900" cy="380" r="160" fill="url(#hglow)" stop-color={game.theme.accent.hex}/>
        <g fill={game.theme.primary.hex} opacity="0.5">
          <circle cx="120" cy="120" r="2"/><circle cx="320" cy="240" r="1.5"/><circle cx="520" cy="160" r="1"/><circle cx="720" cy="80" r="2"/>
          <circle cx="1020" cy="220" r="1.5"/><circle cx="180" cy="380" r="1.5"/><circle cx="980" cy="100" r="1"/><circle cx="600" cy="420" r="2"/>
        </g>
      </svg>

      <div class="relative max-w-5xl mx-auto px-6 sm:px-10 pt-16 sm:pt-24 pb-12">
        <div class="flex flex-col items-center text-center reveal">
          <div class="mb-6 flex items-center gap-3 font-display tracking-[0.3em] text-xs uppercase" style={`color:${game.theme.accent.hex}`}>
            <span class="block w-8 h-px" style={`background:${game.theme.accent.hex}`}></span>
            <span>Tomo del Cristal</span>
            <span class="block w-8 h-px" style={`background:${game.theme.accent.hex}`}></span>
          </div>
          <Logo size={96} game={game} />
          <h1 class="mt-8 font-display text-[clamp(2.5rem,7vw,5.5rem)] leading-[0.95] tracking-[0.04em]">
            <span class="block text-[var(--color-text-soft)] text-[0.5em] tracking-[0.3em] uppercase mb-2">Guía</span>
            <span class="block bg-gradient-to-br from-[var(--color-text)] via-[var(--color-crystal-2)] to-[var(--color-gold)] bg-clip-text text-transparent">{game.title}</span>
          </h1>
          <p class="mt-6 max-w-2xl text-[var(--color-text-soft)] text-lg leading-relaxed">
            {game.tagline}
          </p>
          <div class="mt-10 flex flex-wrap items-center justify-center gap-3">
            {structure[0]?.items[0] && (
              <a href={`/${game.slug}/guia/${structure[0].items[0].slug}`} class="btn btn--primary">
                Empezar la guía
                <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            )}
            <a href="#indice" class="btn">Ver índice completo</a>
          </div>
        </div>
      </div>
    </section>

    <section class="max-w-5xl mx-auto px-6 sm:px-10 py-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
        {stats.map((s) => (
          <div class="card p-5">
            <div class="font-display text-3xl" style={`color:${s.accent}`}>{s.value}</div>
            <div class="mt-1 font-ui text-[0.7rem] uppercase tracking-widest text-[var(--color-text-mute)]">{s.label}</div>
          </div>
        ))}
      </div>
    </section>

    <section id="indice" class="max-w-5xl mx-auto px-6 sm:px-10 py-12">
      <div class="text-center mb-10">
        <div class="font-display tracking-[0.3em] text-xs uppercase mb-3" style={`color:${game.theme.accent.hex}`}>Arquitectura</div>
        <h2 class="font-display text-3xl sm:text-4xl">El índice del viaje</h2>
        <p class="mt-3 text-[var(--color-text-soft)] max-w-xl mx-auto">Cada capítulo guarda los secretos de un lugar, un combate o un corazón.</p>
      </div>

      <div class="space-y-8">
        {structure.map((d, i) => {
          const accent = accentColors[i % accentColors.length];
          return (
            <div class="card p-6 sm:p-7">
              <div class="flex items-baseline justify-between mb-5 gap-4">
                <div class="flex items-center gap-3">
                  <span class="font-mono text-[var(--color-text-mute)] text-xs tracking-widest">{(i + 1).toString().padStart(2, "0")}</span>
                  <h3 class="font-display text-2xl tracking-[0.06em]" style={`color:${accent}`}>{d.disc}</h3>
                </div>
                <span class="chip">{d.items.length} capítulos</span>
              </div>
              <ol class="grid sm:grid-cols-2 gap-x-6 gap-y-1">
                {d.items.slice(0, 10).map((it, k) => (
                  <li>
                    <a href={`/${game.slug}/guia/${it.slug}`} class="group flex items-center gap-2.5 py-1.5 text-sm text-[var(--color-text-soft)] hover:text-[var(--color-text)] transition-colors">
                      <span class="font-mono text-[0.7rem] text-[var(--color-text-mute)] w-6 text-right tabular-nums">{(k + 1).toString().padStart(2, "0")}</span>
                      <span class="truncate group-hover:translate-x-0.5 transition-transform">{it.title}</span>
                    </a>
                  </li>
                ))}
                {d.items.length > 10 && (
                  <li class="sm:col-span-2 text-[0.8rem] text-[var(--color-text-mute)] italic">+ {d.items.length - 10} más…</li>
                )}
              </ol>
            </div>
          );
        })}
      </div>
    </section>

    <footer class="max-w-5xl mx-auto px-6 sm:px-10 py-12 text-center text-[0.78rem] text-[var(--color-text-mute)] font-ui">
      <div class="crystal-divider" aria-hidden="true">
        <svg viewBox="0 0 20 20" width="18" height="18" fill="currentColor" style={`color:${game.theme.accent.hex}`}><path d="M10 1 L18 7 L15 18 L5 18 L2 7 Z"/></svg>
      </div>
      <p>
        Contenido adaptado de <a href={game.baseUrl + game.indexHref} class="text-[var(--color-text-soft)] hover:text-[var(--color-crystal)] underline-offset-2 hover:underline" target="_blank" rel="noopener">Eliteguias</a>.
        {game.title} es una obra de {game.developer}. Esta es una guía fan-made sin ánimo de lucro.
      </p>
      <p class="mt-3">
        <a href="/" class="text-[var(--color-text-soft)] hover:text-[var(--color-crystal)] underline-offset-2 hover:underline">← Ver otros juegos</a>
      </p>
    </footer>
    <div class="h-24 lg:h-0"></div>
  </div>
</GuideLayout>
