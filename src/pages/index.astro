---
import "../styles/global.css";
import { GAMES, type Game } from "../lib/games";
import { isGameAvailable, totalPagesFor } from "../lib/guide";
import Logo from "../components/Logo.astro";

const games: Array<Game & { available: boolean; total: number }> = GAMES.map((g) => ({
  ...g,
  available: isGameAvailable(g.slug),
  total: totalPagesFor(g.slug),
}));
---
<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="color-scheme" content="dark light" />
    <meta name="description" content="Guías completas de Final Fantasy — oscuras, navegables, con búsqueda, progreso y modo claro." />
    <meta name="theme-color" content="#0c0a1f" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#f1e6c4" media="(prefers-color-scheme: light)" />
    <meta property="og:title" content="Tomo del Cristal — Guías de Final Fantasy" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Cinzel:wght@500;600;700&family=Spectral:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400;1,500&family=Manrope:wght@500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
    />
    <title>Tomo del Cristal — Guías de Final Fantasy</title>
  </head>
  <body>
    <div class="relative z-10 min-h-screen">
      <main class="max-w-6xl mx-auto px-6 sm:px-10 py-12 sm:py-20">
        <header class="text-center mb-16 reveal">
          <div class="mb-6 flex items-center justify-center gap-3 font-display tracking-[0.3em] text-xs uppercase text-[var(--color-gold)]">
            <span class="block w-8 h-px bg-[var(--color-gold)]"></span>
            <span>Tomo del Cristal</span>
            <span class="block w-8 h-px bg-[var(--color-gold)]"></span>
          </div>
          <h1 class="font-display text-[clamp(2.5rem,6vw,4.5rem)] leading-[0.95] tracking-[0.04em]">
            <span class="block bg-gradient-to-br from-[var(--color-text)] via-[var(--color-crystal-2)] to-[var(--color-gold)] bg-clip-text text-transparent">Guías de Final Fantasy</span>
          </h1>
          <p class="mt-5 max-w-2xl mx-auto text-[var(--color-text-soft)] text-lg leading-relaxed">
            Cada guía, una <em class="text-[var(--color-crystal-2)] not-italic">toma</em>: walkthrough completo, extras, búsqueda, progreso y modo oscuro.
            Selecciona tu cristal.
          </p>
        </header>

        <section class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {games.map((g) => {
            const status = g.available ? "available" : "soon";
            return (
              <a
                href={g.available ? `/${g.slug}/` : "#"}
                class={`card p-6 sm:p-7 group block relative overflow-hidden transition-all ${g.available ? "hover:border-[var(--color-crystal)]/50 cursor-pointer" : "opacity-60 cursor-not-allowed"}`}
                style={!g.available ? "pointer-events: none" : ""}
              >
                <!-- Theme preview stripe -->
                <div
                  class="absolute top-0 inset-x-0 h-1"
                  style={`background: linear-gradient(90deg, ${g.theme.primary.hex}, ${g.theme.accent.hex})`}
                  aria-hidden="true"
                />

                <div class="flex items-start justify-between gap-3">
                  <Logo size={48} game={g} />
                  <div class="text-right">
                    <div class="font-mono text-[0.7rem] text-[var(--color-text-mute)]">{g.year}</div>
                    {status === "soon" && (
                      <span class="font-ui text-[0.6rem] uppercase tracking-widest text-[var(--color-text-mute)] mt-1 inline-block">próximamente</span>
                    )}
                  </div>
                </div>

                <h2 class="mt-5 font-display text-2xl tracking-wide text-[var(--color-text)] group-hover:text-[var(--color-crystal-2)] transition-colors">
                  {g.title}
                </h2>
                <p class="mt-3 text-[0.9rem] text-[var(--color-text-soft)] leading-relaxed">
                  {g.tagline}
                </p>

                <div class="mt-5 flex items-center gap-2 flex-wrap">
                  {g.platforms.slice(0, 3).map((p) => (
                    <span class="chip text-[0.6rem] !py-0.5 !px-2">{p}</span>
                  ))}
                </div>

                <div class="mt-6 pt-4 border-t border-[var(--color-border-soft)] flex items-center justify-between text-[0.78rem]">
                  <div class="flex items-center gap-3 font-ui text-[var(--color-text-mute)]">
                    <span>{g.total} páginas</span>
                    <span class="opacity-50">·</span>
                    <span>{g.sections.length} secciones</span>
                  </div>
                  {g.available && (
                    <span class="flex items-center gap-1 font-ui text-[var(--color-crystal)] group-hover:translate-x-1 transition-transform">
                      Abrir
                      <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
                    </span>
                  )}
                </div>
              </a>
            );
          })}
        </section>

        <footer class="mt-20 text-center text-[0.78rem] text-[var(--color-text-mute)] font-ui">
          <div class="crystal-divider" aria-hidden="true">
            <svg viewBox="0 0 20 20" width="18" height="18" fill="currentColor" class="text-[var(--color-gold)]"><path d="M10 1 L18 7 L15 18 L5 18 L2 7 Z"/></svg>
          </div>
          <p>
            Contenido adaptado de <a href="https://www.eliteguias.com/" target="_blank" rel="noopener" class="text-[var(--color-text-soft)] hover:text-[var(--color-crystal)] underline-offset-2 hover:underline">Eliteguias</a>.
            Final Fantasy es una marca registrada de Square Enix. Guías fan-made sin ánimo de lucro.
          </p>
        </footer>
      </main>
    </div>

    <script is:inline>
      (() => {
        const root = document.documentElement;
        const KEY = "guide-theme";
        const stored = localStorage.getItem(KEY);
        const isLight = stored === "light";
        if (isLight) root.classList.add("light");
      })();
    </script>
  </body>
</html>
