---
// Script global de progreso: lee/escribe localStorage y actualiza TODA la UI.
// La key es por juego, así que el progreso de FF9 no contamina FF7.
interface Props { gameSlug: string; }
const { gameSlug } = Astro.props;
const KEY = `guide-progress-${gameSlug}`;
---
<script is:inline define:vars={{ KEY }}>
  (() => {
    const get = () => {
      try { return new Set(JSON.parse(localStorage.getItem(KEY) || "[]")); }
      catch { return new Set(); }
    };
    const save = (s) => localStorage.setItem(KEY, JSON.stringify([...s]));

    function paint() {
      const s = get();
      document.querySelectorAll("[data-progress-toggle]").forEach((btn) => {
        const slug = btn.getAttribute("data-progress-toggle");
        const done = s.has(slug);
        btn.setAttribute("aria-pressed", done ? "true" : "false");
        btn.classList.toggle("is-done", done);
        const label = btn.querySelector(".progress-label");
        if (label) label.textContent = done ? "Capítulo completado" : "Marcar completado";
        const icon = btn.querySelector(".progress-icon svg");
        if (icon) {
          icon.setAttribute("fill", done ? "var(--color-crystal)" : "none");
          icon.setAttribute("stroke", done ? "var(--color-crystal-2)" : "currentColor");
        }
        const check = btn.querySelector(".progress-check");
        if (check) check.style.opacity = done ? "1" : "0";
        if (done) {
          btn.classList.add("border-[var(--color-crystal)]/50", "bg-[var(--color-crystal)]/12");
          btn.classList.remove("border-[var(--color-border)]", "bg-[var(--color-surface-2)]/60");
        } else {
          btn.classList.remove("border-[var(--color-crystal)]/50", "bg-[var(--color-crystal)]/12");
          btn.classList.add("border-[var(--color-border)]", "bg-[var(--color-surface-2)]/60");
        }
      });
      // Marcar items en la sidebar
      document.querySelectorAll("[data-nav-slug]").forEach((el) => {
        const slug = el.getAttribute("data-nav-slug");
        el.classList.toggle("is-completed", s.has(slug));
      });
      // Header: progreso global
      const overall = document.querySelector("[data-progress-overall]");
      if (overall) {
        const total = overall.getAttribute("data-progress-overall");
        const t = parseInt(total, 10);
        const done = document.querySelectorAll("[data-nav-slug].is-completed").length;
        const pct = t ? Math.round((done / t) * 100) : 0;
        overall.textContent = `${done} / ${t} (${pct}%)`;
        const bar = document.querySelector("[data-progress-bar]");
        if (bar) bar.style.width = pct + "%";
      }
    }

    document.addEventListener("click", (e) => {
      const t = e.target;
      if (!(t instanceof Element)) return;
      const btn = t.closest("[data-progress-toggle]");
      if (!btn) return;
      e.preventDefault();
      const slug = btn.getAttribute("data-progress-toggle");
      const s = get();
      if (s.has(slug)) s.delete(slug);
      else s.add(slug);
      save(s);
      paint();
    });

    // Pintar al cargar
    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", paint);
    } else {
      paint();
    }
  })();
</script>
