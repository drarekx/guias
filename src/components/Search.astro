---
import { SEARCH_INDEX, search } from "../lib/search";
// Inyectamos el índice en el cliente
const indexJson = JSON.stringify(SEARCH_INDEX);
---
<button
  id="search-trigger"
  type="button"
  class="w-full flex items-center gap-3 px-3 py-2.5 rounded-md text-sm text-[var(--color-text-mute)] bg-[var(--color-surface-2)]/50 border border-[var(--color-border-soft)] hover:border-[var(--color-border)] hover:text-[var(--color-text-soft)] transition-colors group"
  aria-label="Buscar en la guía"
>
  <svg class="w-4 h-4 opacity-70 group-hover:opacity-100" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
    <circle cx="11" cy="11" r="7" />
    <path d="m20 20-3.5-3.5" />
  </svg>
  <span class="flex-1 text-left">Buscar en la guía…</span>
  <kbd class="hidden md:inline-flex font-mono text-[0.65rem] px-1.5 py-0.5 rounded border border-[var(--color-border)] bg-[var(--color-surface-1)] text-[var(--color-text-mute)]">⌘K</kbd>
</button>

<div
  id="search-modal"
  class="fixed inset-0 z-[100] hidden items-start justify-center pt-[12vh] px-4"
  role="dialog"
  aria-modal="true"
  aria-label="Buscar"
>
  <div id="search-backdrop" class="absolute inset-0 bg-[var(--color-void)]/85 backdrop-blur-sm"></div>
  <div class="relative w-full max-w-2xl card reveal">
    <div class="flex items-center gap-3 px-5 py-4 border-b border-[var(--color-border-soft)]">
      <svg class="w-5 h-5 text-[var(--color-crystal)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="11" cy="11" r="7" />
        <path d="m20 20-3.5-3.5" />
      </svg>
      <input
        id="search-input"
        type="text"
        placeholder="Busca una zona, personaje, jefe, objeto…"
        class="flex-1 bg-transparent outline-none text-base text-[var(--color-text)] placeholder:text-[var(--color-text-mute)]"
        autocomplete="off"
        spellcheck="false"
      />
      <kbd class="font-mono text-[0.7rem] px-2 py-0.5 rounded border border-[var(--color-border)] bg-[var(--color-surface-1)] text-[var(--color-text-mute)]">esc</kbd>
    </div>
    <div id="search-results" class="max-h-[60vh] overflow-y-auto p-2">
      <div class="px-4 py-8 text-center text-sm text-[var(--color-text-mute)]">
        Empieza a escribir para buscar en las <strong class="text-[var(--color-gold)]" id="search-total">…</strong> páginas.
      </div>
    </div>
    <div class="flex items-center justify-between gap-4 px-5 py-3 border-t border-[var(--color-border-soft)] text-[0.7rem] text-[var(--color-text-mute)] font-ui">
      <div class="flex items-center gap-3">
        <span class="flex items-center gap-1"><kbd class="font-mono px-1.5 py-0.5 rounded border border-[var(--color-border)]">↑↓</kbd> navegar</span>
        <span class="flex items-center gap-1"><kbd class="font-mono px-1.5 py-0.5 rounded border border-[var(--color-border)]">↵</kbd> abrir</span>
        <span class="flex items-center gap-1"><kbd class="font-mono px-1.5 py-0.5 rounded border border-[var(--color-border)]">esc</kbd> cerrar</span>
      </div>
      <span class="text-[var(--color-text-mute)]/70">Tomo del Cristal</span>
    </div>
  </div>
</div>

<script is:inline define:vars={{ indexJson }}>
  (() => {
    const INDEX = JSON.parse(indexJson);
    const TOTAL = INDEX.length;
    const modal = document.getElementById("search-modal");
    const input = document.getElementById("search-input");
    const results = document.getElementById("search-results");
    const trigger = document.getElementById("search-trigger");
    const backdrop = document.getElementById("search-backdrop");
    const totalEl = document.getElementById("search-total");
    if (totalEl) totalEl.textContent = TOTAL;

    const escapeHtml = (s) => s.replace(/[&<>"']/g, (c) => ({"&":"&amp;","<":"&lt;",">":"&gt;","\"":"&quot;","'":"&#39;"}[c]));
    const escapeRe = (s) => s.replace(/[.*+?^${}()|[\]\\]/g, "\\$&");

    function searchFn(q) {
      q = (q || "").trim().toLowerCase();
      if (q.length < 2) return [];
      const tokens = q.split(/\s+/).filter(Boolean);
      const hits = [];
      for (const doc of INDEX) {
        const text = doc.text;
        let score = 0;
        const ranges = [];
        for (const t of tokens) {
          const re = new RegExp(escapeRe(t), "gi");
          let m;
          while ((m = re.exec(text)) !== null) {
            score += m[0].length;
            ranges.push([m.index, m.index + m[0].length]);
            if (ranges.length > 16) break;
          }
          if (ranges.length > 16) break;
        }
        if (!score) continue;
        if (doc.title.toLowerCase().includes(q)) score += 50;
        if (doc.headings.some((h) => h.text.toLowerCase().includes(q))) score += 20;

        const first = ranges[0] || [0, 0];
        const a = Math.max(0, first[0] - 50);
        const b = Math.min(text.length, a + 200);
        let snip = text.slice(a, b);
        if (a > 0) snip = "…" + snip;
        if (b < text.length) snip += "…";
        // highlight
        const merged = mergeRanges(ranges.filter((r) => r[0] >= a && r[1] <= b).map((r) => [r[0] - a, r[1] - a]));
        let hi = "";
        let last = 0;
        for (const [s, e] of merged) {
          hi += escapeHtml(snip.slice(last, s));
          hi += "<mark>" + escapeHtml(snip.slice(s, e)) + "</mark>";
          last = e;
        }
        hi += escapeHtml(snip.slice(last));
        hits.push({ slug: doc.slug, title: doc.title, disc: doc.disc, score, snippet: hi });
      }
      hits.sort((a, b) => b.score - a.score);
      return hits.slice(0, 24);
    }

    function mergeRanges(rs) {
      if (!rs.length) return [];
      const s = [...rs].sort((a, b) => a[0] - b[0]);
      const out = [s[0]];
      for (let i = 1; i < s.length; i++) {
        const last = out[out.length - 1];
        if (s[i][0] <= last[1] + 1) last[1] = Math.max(last[1], s[i][1]);
        else out.push(s[i]);
      }
      return out;
    }

    let current = [];
    let active = 0;

    function open() {
      modal.classList.remove("hidden");
      modal.classList.add("flex");
      requestAnimationFrame(() => input?.focus());
      document.body.style.overflow = "hidden";
    }
    function close() {
      modal.classList.add("hidden");
      modal.classList.remove("flex");
      if (input) input.value = "";
      results.innerHTML = `<div class="px-4 py-8 text-center text-sm text-[var(--color-text-mute)]">Empieza a escribir para buscar en las <strong class="text-[var(--color-gold)]">${TOTAL}</strong> páginas.</div>`;
      current = [];
      active = 0;
      document.body.style.overflow = "";
    }

    function render(q) {
      const hits = searchFn(q);
      current = hits;
      active = 0;
      if (!hits.length) {
        results.innerHTML = q.length < 2
          ? `<div class="px-4 py-8 text-center text-sm text-[var(--color-text-mute)]">Empieza a escribir para buscar en las <strong class="text-[var(--color-gold)]">${TOTAL}</strong> páginas.</div>`
          : `<div class="px-4 py-10 text-center text-sm text-[var(--color-text-mute)]">Sin resultados para <span class="text-[var(--color-text-soft)] font-medium">"${escapeHtml(q)}"</span></div>`;
        return;
      }
      results.innerHTML = hits.map((h, i) => `
        <a href="/${h.game}/guia/${h.slug}" data-idx="${i}" class="search-item flex flex-col gap-1.5 px-4 py-3 rounded-md ${i === 0 ? "bg-[var(--color-surface-3)]" : "hover:bg-[var(--color-surface-2)]"} transition-colors">
          <div class="flex items-center gap-2 flex-wrap">
            <span class="font-mono text-[0.65rem] uppercase tracking-widest text-[var(--color-gold)]">${escapeHtml(h.game.toUpperCase())}</span>
            <span class="opacity-50 text-[var(--color-text-mute)]">·</span>
            <span class="chip !py-0.5 !px-2 !text-[0.6rem]" style="background:color-mix(in oklab, var(--color-crystal) 14%, var(--color-surface-1)); border-color:color-mix(in oklab, var(--color-crystal) 40%, var(--color-border)); color:var(--color-crystal-2)">${escapeHtml(h.disc)}</span>
            <span class="font-display text-[0.95rem] text-[var(--color-text)]">${escapeHtml(h.title)}</span>
          </div>
          <div class="text-[0.8rem] text-[var(--color-text-soft)] leading-snug">${h.snippet}</div>
        </a>
      `).join("");
    }

    trigger?.addEventListener("click", open);
    backdrop?.addEventListener("click", close);
    input?.addEventListener("input", (e) => render(e.target.value));

    input?.addEventListener("keydown", (e) => {
      if (e.key === "ArrowDown") {
        e.preventDefault();
        active = Math.min(active + 1, current.length - 1);
        updateActive();
      } else if (e.key === "ArrowUp") {
        e.preventDefault();
        active = Math.max(active - 1, 0);
        updateActive();
      } else if (e.key === "Enter") {
        e.preventDefault();
        const h = current[active];
        if (h) window.location.href = `/guia/${h.slug}`;
      } else if (e.key === "Escape") {
        close();
      }
    });

    function updateActive() {
      results.querySelectorAll(".search-item").forEach((el, i) => {
        el.classList.toggle("bg-[var(--color-surface-3)]", i === active);
        if (i === active) el.scrollIntoView({ block: "nearest" });
      });
    }

    document.addEventListener("keydown", (e) => {
      if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === "k") {
        e.preventDefault();
        if (modal.classList.contains("hidden")) open();
        else close();
      } else if (e.key === "Escape" && !modal.classList.contains("hidden")) {
        close();
      } else if (e.key === "/" && document.activeElement?.tagName !== "INPUT" && document.activeElement?.tagName !== "TEXTAREA") {
        e.preventDefault();
        open();
      }
    });
  })();
</script>
