---
// Toggle dark/light mode.
// OJO: el botón está duplicado (sidebar + bottom-bar móvil),
// por eso usamos delegación de eventos en document, no getElementById.
// La key de localStorage es global (preferencia del usuario, no del juego).
---
<button
  type="button"
  class="theme-toggle btn btn--icon btn--ghost relative"
  aria-label="Cambiar tema"
>
  <svg class="theme-icon-dark w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
  </svg>
  <svg class="theme-icon-light w-5 h-5 hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
    <circle cx="12" cy="12" r="4" />
    <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41" />
  </svg>
</button>

<script is:inline>
  (() => {
    // <ThemeToggle /> se renderiza dos veces (sidebar + bottom-bar móvil),
    // así que el script se ejecuta dos veces. Sin este flag, dos listeners
    // harían add+remove = nada cambia.
    if (window.__themeInit) return;
    window.__themeInit = true;

    const root = document.documentElement;
    const KEY = "guide-theme";
    const stored = localStorage.getItem(KEY);
    const isLight = stored === "light";
    if (isLight) root.classList.add("light");

    const applyIcons = () => {
      const light = root.classList.contains("light");
      document.querySelectorAll(".theme-icon-dark").forEach((el) => el.classList.toggle("hidden", light));
      document.querySelectorAll(".theme-icon-light").forEach((el) => el.classList.toggle("hidden", !light));
    };
    applyIcons();

    document.addEventListener("click", (e) => {
      const btn = e.target instanceof Element ? e.target.closest(".theme-toggle") : null;
      if (!btn) return;
      root.classList.toggle("light");
      const nowLight = root.classList.contains("light");
      localStorage.setItem(KEY, nowLight ? "light" : "dark");
      applyIcons();
    });
  })();
</script>
