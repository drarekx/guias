---
// Barra de progreso de lectura: línea finísima en la parte superior
// que se llena según el scroll dentro del artículo.
---
<div class="reading-progress fixed top-0 left-0 right-0 h-[3px] bg-transparent z-[60] pointer-events-none" aria-hidden="true">
  <div id="reading-progress-bar" class="h-full bg-gradient-to-r from-[var(--color-crystal)] to-[var(--color-gold)] transition-[width] duration-75 ease-out" style="width: 0%"></div>
</div>

<script is:inline>
  (() => {
    if (window.__readingProgressInit) return;
    window.__readingProgressInit = true;

    const bar = document.getElementById("reading-progress-bar");
    if (!bar) return;

    let ticking = false;
    function update() {
      const h = document.documentElement;
      const max = h.scrollHeight - h.clientHeight;
      const pct = max > 0 ? Math.min(100, Math.max(0, (h.scrollTop / max) * 100)) : 0;
      bar.style.width = pct + "%";
      ticking = false;
    }

    window.addEventListener("scroll", () => {
      if (!ticking) {
        requestAnimationFrame(update);
        ticking = true;
      }
    }, { passive: true });
    window.addEventListener("resize", update, { passive: true });
    update();
  })();
</script>
