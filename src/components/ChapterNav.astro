---
import type { PageMeta } from "../lib/guide";
import type { Game } from "../lib/games";

interface Props { game: Game; meta: PageMeta; }
const { game, meta } = Astro.props;

// Solo se muestra si hay prev o next
if (!meta.prev && !meta.next) return Astro.redirect ? null : null;
---
{/* Sticky debajo del header. Se vuelve sticky al hacer scroll. */}
<nav
  id="chapter-nav"
  aria-label="Navegación de capítulo"
  class="chapter-nav sticky top-0 z-40 backdrop-blur-md bg-[var(--color-bg)]/85 border-b border-[var(--color-border-soft)] -mx-5 sm:mx-0"
>
  <div class="flex items-center gap-2 px-5 sm:px-0">
    {meta.prev ? (
      <a
        href={`/${game.slug}/guia/${meta.prev.slug}`}
        class="group flex-1 min-w-0 flex items-center gap-2 py-2.5 text-sm text-[var(--color-text-soft)] hover:text-[var(--color-crystal-2)] transition-colors"
        title={meta.prev.title}
      >
        <svg class="w-3.5 h-3.5 shrink-0 group-hover:-translate-x-0.5 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="m15 6-6 6 6 6"/>
        </svg>
        <span class="font-ui text-[0.65rem] uppercase tracking-widest text-[var(--color-text-mute)] shrink-0 hidden sm:inline">Anterior</span>
        <span class="truncate">{meta.prev.title}</span>
      </a>
    ) : (
      <span class="flex-1"></span>
    )}

    <div class="h-5 w-px bg-[var(--color-border-soft)]"></div>

    {meta.next ? (
      <a
        href={`/${game.slug}/guia/${meta.next.slug}`}
        class="group flex-1 min-w-0 flex items-center justify-end gap-2 py-2.5 text-sm text-[var(--color-text-soft)] hover:text-[var(--color-gold)] transition-colors text-right"
        title={meta.next.title}
      >
        <span class="truncate">{meta.next.title}</span>
        <span class="font-ui text-[0.65rem] uppercase tracking-widest text-[var(--color-text-mute)] shrink-0 hidden sm:inline">Siguiente</span>
        <svg class="w-3.5 h-3.5 shrink-0 group-hover:translate-x-0.5 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="m9 6 6 6-6 6"/>
        </svg>
      </a>
    ) : (
      <span class="flex-1"></span>
    )}
  </div>
</nav>
