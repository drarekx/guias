---
// Marcador de progreso: botón que alterna el slug en localStorage
interface Props { slug: string; }
const { slug } = Astro.props;
---
<button
  type="button"
  data-progress-toggle={slug}
  class="progress-toggle group inline-flex items-center gap-2.5 pl-3 pr-4 py-2 rounded-full border border-[var(--color-border)] bg-[var(--color-surface-2)]/60 hover:border-[var(--color-crystal)]/50 hover:bg-[var(--color-surface-3)]/60 transition-all font-ui text-sm"
  aria-pressed="false"
>
  <span class="progress-icon relative w-5 h-5 inline-flex items-center justify-center">
    <svg viewBox="0 0 14 14" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.4" class="text-[var(--color-text-mute)] group-hover:text-[var(--color-crystal)] transition-colors">
      <path d="M7 1 L12.5 5.5 L10 12 L4 12 L1.5 5.5 Z" />
      <path d="M7 1 L7 12 M1.5 5.5 L12.5 5.5 M4 12 L10 5.5 M10 12 L4 5.5" stroke-width="0.5" opacity="0.5" />
    </svg>
    <span class="absolute inset-0 flex items-center justify-center opacity-0 progress-check text-[var(--color-crystal-ink)]">
      <svg viewBox="0 0 24 24" width="10" height="10" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
        <path d="M5 12l5 5L20 7" />
      </svg>
    </span>
  </span>
  <span class="progress-label text-[var(--color-text-soft)] group-hover:text-[var(--color-text)] transition-colors">Marcar completado</span>
</button>

