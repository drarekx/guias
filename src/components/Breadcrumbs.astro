---
import type { Game } from "../lib/games";
interface Props {
  game: Game;
  disc: string;
  title: string;
  slug: string;
}
const { game, disc, title } = Astro.props;
---
<nav aria-label="Migas" class="flex items-center gap-2 text-[0.78rem] font-ui text-[var(--color-text-mute)] mb-4 flex-wrap">
  <a href="/" class="hover:text-[var(--color-crystal)] transition-colors">Juegos</a>
  <svg class="w-3 h-3 opacity-50" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 6 6 6-6 6"/></svg>
  <a href={`/${game.slug}/`} class="hover:text-[var(--color-crystal)] transition-colors">{game.shortTitle}</a>
  <svg class="w-3 h-3 opacity-50" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 6 6 6-6 6"/></svg>
  <span class="chip !py-0.5 !px-2 !text-[0.65rem]" style="background:color-mix(in oklab, var(--color-crystal) 14%, var(--color-surface-1)); border-color:color-mix(in oklab, var(--color-crystal) 40%, var(--color-border)); color:var(--color-crystal-2)">{disc}</span>
  <svg class="w-3 h-3 opacity-50" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 6 6 6-6 6"/></svg>
  <span class="text-[var(--color-text-soft)] truncate max-w-[40ch]">{title}</span>
</nav>
